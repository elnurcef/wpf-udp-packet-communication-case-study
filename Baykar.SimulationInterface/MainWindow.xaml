<Window x:Class="Baykar.SimulationInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Baykar Simulation Interface"
        Width="1100"
        Height="760"
        MinWidth="1000"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Baykar Simulation Interface" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Simulated avionics unit monitor"
                           Margin="0,4,0,0"
                           FontSize="14"
                           Foreground="#555555" />
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Grid.Column="0" Header="Simulation Status Panel" Margin="0,0,10,16">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,3">
                            <Run Text="Simulation Status: " FontWeight="SemiBold" />
                            <Run Text="{Binding SimulationStatus, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Listener Status: " FontWeight="SemiBold" />
                            <Run Text="{Binding ListenerStatus, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Selected Protocol: " FontWeight="SemiBold" />
                            <Run Text="{Binding SelectedProtocol, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Local Port: " FontWeight="SemiBold" />
                            <Run Text="{Binding LocalPortText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Remote Port: " FontWeight="SemiBold" />
                            <Run Text="{Binding RemotePortText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="0" Grid.Column="1" Header="Transmission Panel" Margin="10,0,0,16">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,3">
                            <Run Text="Communication Packet 1 Sent Count: " FontWeight="SemiBold" />
                            <Run Text="{Binding CommunicationPacket1SentCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Communication Packet 2 Sent Count: " FontWeight="SemiBold" />
                            <Run Text="{Binding CommunicationPacket2SentCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="System Time: " FontWeight="SemiBold" />
                            <Run Text="{Binding SystemTime, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Valid Packet Count: " FontWeight="SemiBold" />
                            <Run Text="{Binding ValidPacketCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Invalid Packet Count: " FontWeight="SemiBold" />
                            <Run Text="{Binding InvalidPacketCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="0" Header="Received Command Panel" Margin="0,0,10,16">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,3">
                            <Run Text="Last Received Command: " FontWeight="SemiBold" />
                            <Run Text="{Binding LastReceivedCommand, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="1" Header="Received Setting Panel" Margin="10,0,0,16">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,3">
                            <Run Text="Last Received Setting: " FontWeight="SemiBold" />
                            <Run Text="{Binding LastReceivedSetting, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3">
                            <Run Text="Last Setting Value: " FontWeight="SemiBold" />
                            <Run Text="{Binding LastSettingValue, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Grid.Column="0" Header="Feedback Panel" Margin="0,0,10,16">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,3">
                            <Run Text="Last Sent Feedback: " FontWeight="SemiBold" />
                            <Run Text="{Binding LastSentFeedback, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Grid.Column="1" Header="Control Buttons" Margin="10,0,0,16">
                    <StackPanel Margin="12" Orientation="Horizontal">
                        <Button Content="Start Simulation" Command="{Binding StartSimulationCommand}" MinWidth="140" Margin="0,0,10,0" />
                        <Button Content="Stop Simulation" Command="{Binding StopSimulationCommand}" MinWidth="140" Margin="0,0,10,0" />
                        <Button Content="Reset Counters" Command="{Binding ResetCountersCommand}" MinWidth="130" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Header="Built Communication Packets">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Last Built Communication Packet 1 Bytes:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,8" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Text="{Binding LastBuiltCommunicationPacket1Bytes, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1"
                                   Text="Last Built Communication Packet 2 Bytes:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding LastBuiltCommunicationPacket2Bytes, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap" />

                        <Button Grid.Row="2"
                                Grid.Column="1"
                                Content="Validate Last Built Packets"
                                Command="{Binding ValidateLastBuiltPacketsCommand}"
                                MinWidth="190"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,8" />

                        <TextBlock Grid.Row="3"
                                   Text="Validation Result:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding PacketValidationResult, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4"
                                   Text="Last Received Packet Bytes:"
                                   FontWeight="SemiBold"
                                   Margin="0,10,10,8" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding LastReceivedPacketBytes, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Margin="0,10,0,8" />

                        <TextBlock Grid.Row="5"
                                   Text="Parser Error:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Text="{Binding ParserErrorMessage, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
